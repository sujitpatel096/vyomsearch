{
    "_comment": "NSE SME Pipeline Configuration File — Copy this file, rename to config.json, and fill in your own values.",

    "api_keys": {
        "groq_api_key": "ENTER_YOUR_GROQ_API_KEY_HERE",
        "gemini_api_key": "ENTER_YOUR_GEMINI_API_KEY_HERE"
    },

    "telegram": {
        "bot_token": "ENTER_YOUR_TELEGRAM_BOT_TOKEN_HERE",
        "chat_id": "ENTER_YOUR_TELEGRAM_CHAT_ID_HERE"
    },

    "window_settings": {
        "_comment": "Market open time = pipeline trigger time = Window 1 start and Window 2 end",
        "_comment2": "Market close time = split point between Window 1 and Window 2",
        "market_open_hour"   : 8,
        "market_open_minute" : 0,
        "market_close_hour"  : 15,
        "market_close_minute": 30
    },

    "pipeline_settings": {
        "batch_chunk_size"       : 3,
        "output_folder_name"     : "NSE SME Announcement",
        "json_log_file"          : "sme_announcements.json",
        "max_text_chars_per_doc" : 3500,
        "_comment_debug"         : "debug_override_hours: set 1/2/3 to test with last N hours as a single window. Set 0 for normal 24-hr dual-window production mode.",
        "debug_override_hours"   : 0
    },

    "rate_limits": {
        "groq_inter_batch_delay_seconds": 3,
        "gemini_retry_wait_seconds"     : 4,
        "batch_pause_min_seconds"       : 20,
        "batch_pause_max_seconds"       : 30
    },

    "google_drive": {
        "token_file"        : "token.json",
        "client_secret_file": "client_secret.json",
        "_comment"          : "token.json is auto-generated on first run when you login via browser"
    },

    "filter": {
        "_comment_noise": "Keywords that strongly indicate routine corporate boilerplate or noise.",
        "noise_keywords": [
            "closure of trading window",
            "trading window closure",
            "loss of share certificate",
            "duplicate share certificate",
            "newspaper advertisement",
            "advertisement in newspaper",
            "dispatch of annual report",
            "notice of annual general meeting",
            "voting results of agm",
            "scrutinizer report",
            "compliance certificate under regulation",
            "regulation 7(3)",
            "regulation 40(9)",
            "regulation 74(5)",
            "dematerialisation of shares",
            "statement of investor complaints",
            "investor grievances report"
        ],

        "noise_threshold_for_rejection": 1,
        "noise_dominant_threshold"      : 2,
        "noise_dominant_material_max"   : 1,

        "_comment_tier1": "Highly unique, high-value strings. 1 single match is an immediate PASS.",
        "tier1_material_phrases": [
            "awarded order",
            "received a prestigious order",
            "bags order",
            "bags prestigious order",
            "successful commissioning",
            "commercial operations",
            "letter of intent",
            "letter of award",
            "contract worth",
            "order worth",
            "financial results for the quarter",
            "audited financial results",
            "unaudited financial results",
            "declaration of dividend",
            "recommendation of dividend",
            "interim dividend",
            "bonus shares",
            "issue of bonus",
            "rights issue",
            "allotment of warrants",
            "conversion of warrants",
            "acquisition of shares",
            "signed a mou",
            "memorandum of understanding",
            "strategic alliance",
            "chief executive officer",
            "chief financial officer",
            "managing director",
            "resignation of chief",
            "resignation of director",
            "resignation of managing",
            "joint venture",
            "capacity expansion",
            "new facility",
            "commenced operations",
            "acquisition of",
            "amalgamation",
            "loss after tax",
            "revenue from operation",
            "total revenue",
            "secures order",
            "receives order",
            "stake acquisition",
            "acquires stake",
            "store opening",
            "warrant conversion"
        ],

        "_comment_tier2": "Short keywords — need regex word boundary to avoid false matches. Need 2+ matches.",
        "tier2_regex_patterns": [
            "\\bcrore\\b",
            "\\bcrores\\b",
            "\\blakh\\b",
            "\\blakhs\\b",
            "\\b\\d+\\s*cr\\b",
            "\\bq[1-4]fy\\d{2}",
            "\\bfy\\s*20[0-9]{2}\\b",
            "\\byoy\\b",
            "\\bqoq\\b",
            "\\bpat\\b",
            "\\bpbt\\b",
            "\\beps\\b",
            "\\bqip\\b",
            "\\bbuyback\\b",
            "\\bmerger\\b",
            "\\bdividend\\b",
            "\\bresignation\\b",
            "\\bappointment\\b"
        ],

        "rules": {
            "min_text_length_chars"         : 100,
            "tier2_min_matches_if_no_tier1" : 2,
            "noise_threshold_for_rejection" : 1,
            "noise_dominant_threshold"      : 2,
            "noise_dominant_material_max"   : 1
        }
    }
}
